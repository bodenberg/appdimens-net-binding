<Project>
  <PropertyGroup>
    <AppDimensBuildTasksProject Condition="Exists('$(MSBuildThisFileDirectory)..\AppDimens.Maui.BuildTasks\AppDimens.Maui.BuildTasks.csproj')">$(MSBuildThisFileDirectory)..\AppDimens.Maui.BuildTasks\AppDimens.Maui.BuildTasks.csproj</AppDimensBuildTasksProject>
    <AppDimensBuildTasksProject Condition="'$(AppDimensBuildTasksProject)' == '' AND Exists('$(MSBuildThisFileDirectory)..\..\AppDimens.Maui.BuildTasks\AppDimens.Maui.BuildTasks.csproj')">$(MSBuildThisFileDirectory)..\..\AppDimens.Maui.BuildTasks\AppDimens.Maui.BuildTasks.csproj</AppDimensBuildTasksProject>
    <AppDimensBuildTasksDll Condition="Exists('$(MSBuildThisFileDirectory)AppDimens.Maui.BuildTasks.dll')">$(MSBuildThisFileDirectory)AppDimens.Maui.BuildTasks.dll</AppDimensBuildTasksDll>
    <AppDimensBuildTasksDll Condition="'$(AppDimensBuildTasksDll)' == ''">$(MSBuildThisFileDirectory)..\AppDimens.Maui.BuildTasks\bin\$(Configuration)\netstandard2.0\AppDimens.Maui.BuildTasks.dll</AppDimensBuildTasksDll>
  </PropertyGroup>

  <Target Name="_AppDimensBuildBuildTasks"
          BeforeTargets="_AppDimensExpandShortDimenMarkup"
          Condition="'$(DisableAppDimensShortMarkupExpansion)' != 'true' AND Exists('$(AppDimensBuildTasksProject)')">
    <MSBuild Projects="$(AppDimensBuildTasksProject)"
             Targets="Build"
             Properties="Configuration=$(Configuration);TargetFramework=netstandard2.0;RuntimeIdentifier=;RuntimeIdentifiers=;BuildProjectReferences=false;AppendRuntimeIdentifierToOutputPath=false" />
  </Target>

  <UsingTask TaskName="AppDimens.Maui.BuildTasks.ExpandShortDimenMarkup"
             AssemblyFile="$(AppDimensBuildTasksDll)"
             Condition="Exists('$(AppDimensBuildTasksDll)')" />

  <!-- Expand {sdp:20} → {sdp:Sdp 20} before MAUI reads MauiXaml (Runtime + XamlC). -->
  <Target Name="_AppDimensExpandShortDimenMarkup"
          BeforeTargets="_MauiXamlComputeInflator"
          DependsOnTargets="_AppDimensBuildBuildTasks"
          Condition="'$(UseMaui)' == 'true' AND '$(DisableAppDimensShortMarkupExpansion)' != 'true' AND '@(MauiXaml)' != '' AND Exists('$(AppDimensBuildTasksDll)')">
    <AssignTargetPath Files="@(MauiXaml)" RootFolder="$(MSBuildProjectDirectory)">
      <Output TaskParameter="AssignedFiles" ItemName="_AppDimensMauiXamlInput" />
    </AssignTargetPath>

    <ExpandShortDimenMarkup Inputs="@(_AppDimensMauiXamlInput)"
                            IntermediateOutputPath="$(IntermediateOutputPath)">
      <Output TaskParameter="Outputs" ItemName="_AppDimensExpandedMauiXaml" />
    </ExpandShortDimenMarkup>

    <ItemGroup>
      <MauiXaml Remove="@(MauiXaml)" />
      <MauiXaml Include="@(_AppDimensExpandedMauiXaml)">
        <Link>%(_AppDimensExpandedMauiXaml.RelativePath)</Link>
        <TargetPath>%(_AppDimensExpandedMauiXaml.RelativePath)</TargetPath>
        <Inflator>%(_AppDimensExpandedMauiXaml.Inflator)</Inflator>
      </MauiXaml>
    </ItemGroup>
  </Target>
</Project>

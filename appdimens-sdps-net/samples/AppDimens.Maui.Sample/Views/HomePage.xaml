<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:dimen="clr-namespace:AppDimens.Maui.Xaml;assembly=AppDimens.Maui.Xaml"
             xmlns:sdp="clr-namespace:AppDimens.Maui.Markup;assembly=AppDimens.Maui.Markup"
             xmlns:ssp="clr-namespace:AppDimens.Maui.Markup;assembly=AppDimens.Maui.Markup"
             xmlns:sdpPh="clr-namespace:AppDimens.Maui.Markup;assembly=AppDimens.Maui.Markup"
             xmlns:sdpLwA="clr-namespace:AppDimens.Maui.Markup;assembly=AppDimens.Maui.Markup"
             xmlns:semaPh="clr-namespace:AppDimens.Maui.Markup;assembly=AppDimens.Maui.Markup"
             xmlns:scaled="clr-namespace:AppDimens.Maui.Markup;assembly=AppDimens.Maui.Markup"
             xmlns:sdpRotate="clr-namespace:AppDimens.Maui.Markup;assembly=AppDimens.Maui.Markup"
             xmlns:sdpQualifier="clr-namespace:AppDimens.Maui.Markup;assembly=AppDimens.Maui.Markup"
             x:Class="AppDimens.Maui.Sample.Views.HomePage"
             Title="Início">

    <ScrollView>
        <VerticalStackLayout Padding="{sdp:20}" Spacing="{sdp:4}">
            <Label Text="AppDimens MAUI" Style="{StaticResource PageTitle}" />
            <Label Text="Dimensões responsivas com paridade Android SDP"
                   Style="{StaticResource Caption}" Margin="{sdp:12}" />

            <Border Style="{StaticResource Card}" BackgroundColor="{StaticResource SurfaceElevated}">
                <VerticalStackLayout Spacing="{sdp:6}">
                    <Label Text="Tela atual" FontAttributes="Bold" FontSize="{ssp:14}" TextColor="{StaticResource TextPrimary}" />
                    <Label x:Name="MetricsLabel" Style="{StaticResource Caption}" LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource Card}" Stroke="{StaticResource Primary}">
                <VerticalStackLayout Spacing="{sdp:6}">
                    <Label Text="Duas sintaxes XAML" FontAttributes="Bold" FontSize="{ssp:14}" TextColor="{StaticResource PrimaryLight}" />
                    <Label FontFamily="Courier" FontSize="{ssp:10}" TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap"
                           Text="xmlns:sdp=&quot;clr-namespace:AppDimens.Maui.Markup;assembly=AppDimens.Maui.Markup&quot;&#10;xmlns:dimen=&quot;clr-namespace:AppDimens.Maui.Xaml;assembly=AppDimens.Maui.Xaml&quot;" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="{sdp:8}">
                        <VerticalStackLayout Spacing="{sdp:4}">
                            <Label Text="Short" FontAttributes="Bold" FontSize="{ssp:12}" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="{}{sdp:16}" FontFamily="Courier" FontSize="{ssp:10}" TextColor="{StaticResource TextSecondary}" />
                            <BoxView Color="{StaticResource SdpColor}" WidthRequest="{sdp:16}" HeightRequest="{sdp:16}" CornerRadius="{sdp:4}" HorizontalOptions="Start" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="{sdp:4}">
                            <Label Text="Long (dimen:)" FontAttributes="Bold" FontSize="{ssp:12}" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="{}{dimen:Sdp Value=16}" FontFamily="Courier" FontSize="{ssp:10}" TextColor="{StaticResource TextSecondary}" />
                            <BoxView Color="{StaticResource SdpColor}" WidthRequest="{dimen:Sdp Value=16}" HeightRequest="{dimen:Sdp Value=16}" CornerRadius="{dimen:Sdp Value=4}" HorizontalOptions="Start" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Label Text="Explorar" Style="{StaticResource SectionTitle}" />

            <Border Style="{StaticResource NavCard}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDimensTapped" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{sdp:8}">
                    <VerticalStackLayout Spacing="{sdp:4}">
                        <Label Text="Dimensões base" FontAttributes="Bold" FontSize="{ssp:16}" TextColor="{StaticResource TextPrimary}" />
                        <Label Text="{}{sdp:16} · {}{dimen:Sdp Value=16} · 16.Sdp()"
                               Style="{StaticResource Caption}" />
                    </VerticalStackLayout>
                    <Label Grid.Column="1" Text="›" FontSize="{ssp:28}" TextColor="{StaticResource PrimaryLight}" VerticalOptions="Center" />
                </Grid>
            </Border>

            <Border Style="{StaticResource NavCard}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnInvertersTapped" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{sdp:8}">
                    <VerticalStackLayout Spacing="{sdp:4}">
                        <Label Text="Inversores" FontAttributes="Bold" FontSize="{ssp:16}" TextColor="{StaticResource TextPrimary}" />
                        <Label Text="{}{sdpPh:16} · {}{sdpLwA:16} · {}{semaPh:18}"
                               Style="{StaticResource Caption}" />
                    </VerticalStackLayout>
                    <Label Grid.Column="1" Text="›" FontSize="{ssp:28}" TextColor="{StaticResource PrimaryLight}" VerticalOptions="Center" />
                </Grid>
            </Border>

            <Border Style="{StaticResource NavCard}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAdvancedTapped" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{sdp:8}">
                    <VerticalStackLayout Spacing="{sdp:4}">
                        <Label Text="Avançado" FontAttributes="Bold" FontSize="{ssp:16}" TextColor="{StaticResource TextPrimary}" />
                        <Label Text="{}{scaled:14, Tablet=18} · {}{sdpRotate:30, Rotation=45} · {}{sdpQualifier:16, Qualified=20, QualifierType=SmallWidth, Threshold=600}"
                               Style="{StaticResource Caption}" />
                    </VerticalStackLayout>
                    <Label Grid.Column="1" Text="›" FontSize="{ssp:28}" TextColor="{StaticResource PrimaryLight}" VerticalOptions="Center" />
                </Grid>
            </Border>

            <Border Style="{StaticResource NavCard}" BackgroundColor="#1E1B4B" Stroke="{StaticResource Primary}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBenchmarkTapped" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{sdp:8}">
                    <VerticalStackLayout Spacing="{sdp:4}">
                        <Label Text="Benchmark" FontAttributes="Bold" FontSize="{ssp:16}" TextColor="{StaticResource Accent}" />
                        <Label Text="Medição de lookup SDP/SSP no dispositivo"
                               Style="{StaticResource Caption}" />
                    </VerticalStackLayout>
                    <Label Grid.Column="1" Text="›" FontSize="{ssp:28}" TextColor="{StaticResource Accent}" VerticalOptions="Center" />
                </Grid>
            </Border>

            <Button Text="Atualizar métricas" Style="{StaticResource PrimaryButton}" Clicked="OnRefreshClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
